# Copy to .env.local for local dev (`vercel env pull .env.local` does this for you)

# Your Anthropic API key — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Any long random string — used to sign login session tokens.
# Generate one with: openssl rand -base64 32
JWT_SECRET=

# Auto-filled by Vercel when you connect a Vercel Postgres database
# (Project -> Storage -> Create Database -> Postgres -> Connect)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
